# LoopForge — environment variables
# Recorded mode (the demo path) needs NO keys. These are only for live mode.
# Copy to .env.local (gitignored) and fill in to enable "Run live".

# Primary model path — Cerebras Gemma 4 31B
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gemma-4-31b

# Optional GPU baseline for the live Speed Race (the recorded baseline is OpenAI gpt-oss-120b)
FIREWORKS_API_KEY=
BASELINE_PROVIDER=fireworks
BASELINE_MODEL=accounts/fireworks/models/gpt-oss-120b

# Optional: read keys from an external env file instead of this one
# LOOPFORGE_SOURCE_ENV=/absolute/path/to/your/.env.local
